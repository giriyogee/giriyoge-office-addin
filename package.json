{
  "name": "giriyoge-office-addin",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Microsoft 365 Word task pane add-in built with Angular and Office.js.",
  "scripts": {
    "start:local": "ng serve --configuration local --host localhost --port 4200 --ssl true --ssl-cert \"%USERPROFILE%\\.office-addin-dev-certs\\localhost.crt\" --ssl-key \"%USERPROFILE%\\.office-addin-dev-certs\\localhost.key\"",
    "start:dev": "ng serve --configuration dev --host localhost --port 4300 --ssl true --ssl-cert \"%USERPROFILE%\\.office-addin-dev-certs\\localhost.crt\" --ssl-key \"%USERPROFILE%\\.office-addin-dev-certs\\localhost.key\"",
    "start:uat": "ng serve --configuration uat --host localhost --port 4400 --ssl true --ssl-cert \"%USERPROFILE%\\.office-addin-dev-certs\\localhost.crt\" --ssl-key \"%USERPROFILE%\\.office-addin-dev-certs\\localhost.key\"",
    "build": "ng build --configuration production",
    "build:prod": "ng build --configuration production",
    "build:local": "ng build --configuration local",
    "build:dev": "ng build --configuration dev",
    "build:uat": "ng build --configuration uat",
    "test": "ng test",
    "lint": "ng lint",
    "certs:install": "office-addin-dev-certs install",
    "certs:verify": "office-addin-dev-certs verify",
    "validate:manifest:prod": "office-addin-manifest validate manifests/manifest-prod.xml",
    "validate:manifest:local": "office-addin-manifest validate manifests/manifest-local.xml",
    "validate:manifest:dev": "office-addin-manifest validate manifests/manifest-dev.xml",
    "validate:manifest:uat": "office-addin-manifest validate manifests/manifest-uat.xml",
    "validate:manifests": "npm run validate:manifest:prod && npm run validate:manifest:local && npm run validate:manifest:dev && npm run validate:manifest:uat",
    "sideload:word:local": "office-addin-debugging start manifests/manifest-local.xml desktop --app word --no-debug",
    "sideload:word:dev": "office-addin-debugging start manifests/manifest-dev.xml desktop --app word --no-debug",
    "sideload:word:uat": "office-addin-debugging start manifests/manifest-uat.xml desktop --app word --no-debug",
    "stop:sideload": "office-addin-debugging stop manifests/manifest-local.xml"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/jasmine": "^5.1.5",
    "@types/office-js": "^1.0.550",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.18.0",
    "jasmine-core": "^5.5.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-manifest": "^2.0.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  }
}
